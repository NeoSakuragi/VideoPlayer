<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/cardCreator"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EE1A1A2E"
    android:visibility="gone"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Create Anki Card"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <!-- Word + Reading -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/ccWord"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/ccReading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#AAAAAA"
                android:textSize="18sp"
                android:layout_marginStart="12dp" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/ccFrequency"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#81C784"
                android:textSize="13sp"
                android:background="#33FFFFFF"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp" />
        </LinearLayout>

        <!-- Meaning -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Meaning"
            android:textColor="#7986CB"
            android:textSize="11sp"
            android:layout_marginBottom="2dp" />

        <TextView
            android:id="@+id/ccMeaning"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#DDDDDD"
            android:textSize="14sp"
            android:maxLines="4"
            android:ellipsize="end"
            android:background="#22FFFFFF"
            android:padding="8dp"
            android:layout_marginBottom="10dp" />

        <!-- Sentence -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sentence"
            android:textColor="#7986CB"
            android:textSize="11sp"
            android:layout_marginBottom="2dp" />

        <TextView
            android:id="@+id/ccSentence"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#DDDDDD"
            android:textSize="14sp"
            android:background="#22FFFFFF"
            android:padding="8dp"
            android:layout_marginBottom="10dp" />

        <!-- Screenshot preview -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Screenshot"
            android:textColor="#7986CB"
            android:textSize="11sp"
            android:layout_marginBottom="2dp" />

        <ImageView
            android:id="@+id/ccScreenshot"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:scaleType="centerCrop"
            android:background="#22FFFFFF"
            android:layout_marginBottom="10dp" />

        <!-- Audio timing -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Audio clip"
            android:textColor="#7986CB"
            android:textSize="11sp"
            android:layout_marginBottom="2dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#22FFFFFF"
            android:padding="8dp"
            android:layout_marginBottom="4dp">

            <TextView
                android:id="@+id/ccAudioTiming"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#DDDDDD"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Timing adjustment -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="12dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/ccPadBeforeMinus"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:minWidth="40dp"
                android:padding="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="-"
                android:textSize="16sp"
                android:focusable="true" />

            <TextView
                android:id="@+id/ccPadBeforeLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#AAAAAA"
                android:textSize="11sp"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:text="Before: 0.5s" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/ccPadBeforePlus"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:minWidth="40dp"
                android:padding="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="+"
                android:textSize="16sp"
                android:layout_marginEnd="16dp"
                android:focusable="true" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/ccPadAfterMinus"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:minWidth="40dp"
                android:padding="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="-"
                android:textSize="16sp"
                android:focusable="true" />

            <TextView
                android:id="@+id/ccPadAfterLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#AAAAAA"
                android:textSize="11sp"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:text="After: 0.5s" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/ccPadAfterPlus"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:minWidth="40dp"
                android:padding="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="+"
                android:textSize="16sp"
                android:focusable="true" />
        </LinearLayout>

        <!-- Action buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/ccBtnCancel"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Cancel"
                android:textColor="#999999"
                android:focusable="true" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/ccBtnSend"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Send to Anki"
                android:focusable="true" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
