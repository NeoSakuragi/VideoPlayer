<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1A1A1A">

    <!-- Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="8dp"
        android:background="#222222"
        android:elevation="4dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@android:drawable/ic_menu_revert"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            android:focusable="true" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Settings"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:paddingStart="12dp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Font section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="SUBTITLES"
                android:textColor="#7986CB"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"
                android:layout_marginTop="8dp" />

            <!-- Font selector -->
            <LinearLayout
                android:id="@+id/settingFont"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp"
                android:background="@drawable/focus_highlight"
                android:focusable="true"
                android:clickable="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Font"
                    android:textColor="#EEEEEE"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/tvFontValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Noto Sans JP"
                    android:textColor="#888888"
                    android:textSize="13sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <!-- Font bold -->
            <LinearLayout
                android:id="@+id/settingFontBold"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp"
                android:background="@drawable/focus_highlight"
                android:focusable="true"
                android:clickable="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bold"
                    android:textColor="#EEEEEE"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/tvFontBoldValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Off"
                    android:textColor="#888888"
                    android:textSize="13sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <!-- Font size -->
            <LinearLayout
                android:id="@+id/settingFontSize"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp"
                android:background="@drawable/focus_highlight"
                android:focusable="true"
                android:clickable="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Font size"
                    android:textColor="#EEEEEE"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/tvFontSizeValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="20sp"
                    android:textColor="#888888"
                    android:textSize="13sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <!-- Playback section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="PLAYBACK"
                android:textColor="#7986CB"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"
                android:layout_marginTop="24dp" />

            <LinearLayout
                android:id="@+id/settingHwdec"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp"
                android:background="@drawable/focus_highlight"
                android:focusable="true"
                android:clickable="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hardware decoding"
                    android:textColor="#EEEEEE"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/tvHwdecValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Off (software)"
                    android:textColor="#888888"
                    android:textSize="13sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <!-- Anki section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ANKI CONNECT"
                android:textColor="#7986CB"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"
                android:layout_marginTop="24dp" />

            <!-- Enable -->
            <LinearLayout android:id="@+id/settingAnkiEnabled" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="12dp" android:background="@drawable/focus_highlight" android:focusable="true" android:clickable="true">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="AnkiConnect" android:textColor="#EEEEEE" android:textSize="15sp" />
                <TextView android:id="@+id/tvAnkiValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#888888" android:textSize="13sp" android:layout_marginTop="2dp" />
            </LinearLayout>

            <!-- URL -->
            <LinearLayout android:id="@+id/settingAnkiUrl" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="12dp" android:background="@drawable/focus_highlight" android:focusable="true" android:clickable="true">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="AnkiConnect URL" android:textColor="#EEEEEE" android:textSize="15sp" />
                <TextView android:id="@+id/tvAnkiUrlValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#888888" android:textSize="13sp" android:layout_marginTop="2dp" />
            </LinearLayout>

            <!-- Test connection -->
            <LinearLayout android:id="@+id/settingAnkiTest" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="12dp" android:background="@drawable/focus_highlight" android:focusable="true" android:clickable="true">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Test connection" android:textColor="#7986CB" android:textSize="15sp" />
                <TextView android:id="@+id/tvAnkiTestValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tap to test" android:textColor="#888888" android:textSize="13sp" android:layout_marginTop="2dp" />
            </LinearLayout>

            <!-- Deck -->
            <LinearLayout android:id="@+id/settingAnkiDeck" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="12dp" android:background="@drawable/focus_highlight" android:focusable="true" android:clickable="true">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Deck" android:textColor="#EEEEEE" android:textSize="15sp" />
                <TextView android:id="@+id/tvAnkiDeckValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#888888" android:textSize="13sp" android:layout_marginTop="2dp" />
            </LinearLayout>

            <!-- Note type -->
            <LinearLayout android:id="@+id/settingAnkiNoteType" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="12dp" android:background="@drawable/focus_highlight" android:focusable="true" android:clickable="true">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Note type" android:textColor="#EEEEEE" android:textSize="15sp" />
                <TextView android:id="@+id/tvAnkiNoteTypeValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#888888" android:textSize="13sp" android:layout_marginTop="2dp" />
            </LinearLayout>

            <!-- Tags -->
            <LinearLayout android:id="@+id/settingAnkiTags" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="12dp" android:background="@drawable/focus_highlight" android:focusable="true" android:clickable="true">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tags" android:textColor="#EEEEEE" android:textSize="15sp" />
                <TextView android:id="@+id/tvAnkiTagsValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#888888" android:textSize="13sp" android:layout_marginTop="2dp" />
            </LinearLayout>

            <!-- Dictionaries section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="DICTIONARIES"
                android:textColor="#7986CB"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"
                android:layout_marginTop="24dp" />

            <LinearLayout
                android:id="@+id/dictionariesContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <!-- Field mappings header -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="FIELD MAPPINGS"
                android:textColor="#7986CB"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"
                android:layout_marginTop="24dp" />

            <!-- Dynamic field mapping container -->
            <LinearLayout
                android:id="@+id/fieldMappingsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
